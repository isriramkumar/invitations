<script>
// ── Cursor ───────────────────────────────────────
const C = document.getElementById('C'), CR = document.getElementById('CR');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{ mx=e.clientX; my=e.clientY; C.style.left=mx+'px'; C.style.top=my+'px'; });
(function loop(){ rx+=(mx-rx)*.12; ry+=(my-ry)*.12; CR.style.left=rx+'px'; CR.style.top=ry+'px'; requestAnimationFrame(loop); })();
document.querySelectorAll('.person-frame,.mosaic-item,a').forEach(el=>{
  el.addEventListener('mouseenter',()=>{ C.classList.add('big'); CR.classList.add('big'); });
  el.addEventListener('mouseleave',()=>{ C.classList.remove('big'); CR.classList.remove('big'); });
});

// ── Progress bar ─────────────────────────────────
const PB=document.getElementById('PB');
window.addEventListener('scroll',()=>{
  PB.style.transform=`scaleX(${window.scrollY/(document.body.scrollHeight-window.innerHeight)})`;
});

// ── IntersectionObserver reveals ─────────────────
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('on'); });
},{ threshold:.1 });
document.querySelectorAll('.r,.rl,.rr,.rs').forEach(el=>io.observe(el));

// ── Story letters staggered reveal ───────────────
const storyObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(!e.isIntersecting) return;
    document.querySelectorAll('.story-letter').forEach((l,i)=>{
      setTimeout(()=>l.classList.add('on'), i*55);
    });
    storyObs.disconnect();
  });
},{ threshold:.15 });
const sl=document.getElementById('storyLetters');
if(sl) storyObs.observe(sl);

// ── Story letter lit-up on scroll depth ──────────
const allLetters=document.querySelectorAll('.story-letter');
window.addEventListener('scroll',()=>{
  allLetters.forEach(l=>{
    const rect=l.getBoundingClientRect();
    const pct=1-(rect.top/window.innerHeight);
    if(pct>.35) l.classList.add('lit'); else l.classList.remove('lit');
  });
});

// ── Hero parallax ────────────────────────────────
const heroContent=document.querySelector('.hero-content');
const heroFloral=document.querySelector('.hero-floral');
window.addEventListener('scroll',()=>{
  const sy=window.scrollY,vh=window.innerHeight;
  if(sy<vh){
    if(heroContent){ heroContent.style.transform=`translateY(${sy*.28}px)`; heroContent.style.opacity=1-sy/(vh*.65); }
    if(heroFloral)  heroFloral.style.transform=`translate(-50%,calc(-50% + ${sy*.12}px))`;
  }
});

// ── Floating particles ───────────────────────────
const pts=document.getElementById('pts');
for(let i=0;i<50;i++){
  const p=document.createElement('div'); p.className='pt';
  p.style.cssText=`left:${Math.random()*100}%;top:${30+Math.random()*55}%;--d:${3+Math.random()*5}s;--dl:${-Math.random()*7}s;`;
  pts.appendChild(p);
}

// ── 3D tilt on person frames ──────────────────────
document.querySelectorAll('.person-frame').forEach(f=>{
  f.addEventListener('mousemove',e=>{
    const r=f.getBoundingClientRect();
    const x=((e.clientX-r.left)/r.width-.5)*16;
    const y=((e.clientY-r.top)/r.height-.5)*-16;
    f.style.transform=`translateY(-10px) scale(1.02) rotateX(${y}deg) rotateY(${x}deg)`;
  });
  f.addEventListener('mouseleave',()=>f.style.transform='');
});

// ── Mosaic 3D tilt ────────────────────────────────
document.querySelectorAll('.mosaic-item').forEach(item=>{
  item.addEventListener('mousemove',e=>{
    const r=item.getBoundingClientRect();
    const x=((e.clientX-r.left)/r.width-.5)*6;
    const y=((e.clientY-r.top)/r.height-.5)*-6;
    item.style.transform=`scale(1.01) rotateX(${y}deg) rotateY(${x}deg)`;
  });
  item.addEventListener('mouseleave',()=>item.style.transform='');
});
</script>
