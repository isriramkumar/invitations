    <span class="marquee-item">With Love &amp; Blessings</span>
    <span class="marquee-sep">✦</span>
    <span class="marquee-item">Saravana Nakshatram</span>
    <span class="marquee-sep">✦</span>
    <span class="marquee-item">Saravanan &amp; Valli</span>
    <span class="marquee-sep">✦</span>
    <span class="marquee-item">14th October 2026</span>
    <span class="marquee-sep">✦</span>
    <span class="marquee-item">Vijayawada</span>
    <span class="marquee-sep">✦</span>
    <span class="marquee-item">With Love &amp; Blessings</span>
    <span class="marquee-sep">✦</span>
    <span class="marquee-item">Saravana Nakshatram</span>
    <span class="marquee-sep">✦</span>
  </div>
</div>

<!-- ═══════════════════ SAVE THE DATE ════════ -->
<section class="savedate">
  <div class="savedate-bg-circle"></div>
  <div class="savedate-inner">

    <div class="r">
      <div class="savedate-label">Save the Date</div>
      <div class="savedate-event-name">Subamuhurtham</div>
      <div class="savedate-details">
        <strong>Thursday, 14th October 2026</strong>
        At 09:30 AM<br>
        Saravana Nakshatram<br>
        Palani
      </div>
    </div>

    <div class="savedate-divider-v r" style="transition-delay:.15s"></div>

    <div class="r" style="transition-delay:.1s">
      <div class="savedate-label">Reception</div>
      <div class="savedate-event-name">Reception Evening</div>
      <div class="savedate-details">
        <strong>Friday, 15th October 2026</strong>
        At 07:30 PM<br>
        Saravana Nakshatram<br>
        Palani
      </div>
    </div>

    <div class="savedate-invite r" style="transition-delay:.2s">
